@{
}

@using WebApplication2.Models
@model List<Product>

    <h2 class="display-5">Product Details</h2>

    <table border="1" cellpadding="10" cellspacing="0" class="table">
        <thead>
            <tr>
                <th>PId</th>
                <th>PName</th>
                <th>Category</th>
                <th>Price</th>
            </tr>
        </thead>

        <tbody>
        @foreach(Product item in Model)
        {
            <tr>
                <td>@item.PId</td>
                <td>@item.PName</td>
                <td>@item.Category</td>
                <td>@item.Price</td>
            </tr>
        }
        </tbody>
    </table>