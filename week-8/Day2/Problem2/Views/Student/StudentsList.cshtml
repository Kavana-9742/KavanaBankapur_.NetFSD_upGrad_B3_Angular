@model IEnumerable<WebApplication11.Models.Student>

<h2>Students with Course</h2>

<table border="1">
    <tr>
        <th>Student Name</th>
        <th>Course</th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>@item.StudentName</td>
            <td>@item.Course?.CourseName</td>
        </tr>
    }
</table>

<br />
<a href="/Students/Courses">View Courses</a>
