@{
}

@model WebApplication3.Models.Contact

<h2>Add Contact</h2>

<form asp-action="AddContact">

    Id: <input asp-for="ContactId" />
    <span asp-validation-for="ContactId"></span><br />

    First Name: <input asp-for="FirstName" />
    <span asp-validation-for="FirstName"></span><br />

    Last Name: <input asp-for="LastName" />
    <span asp-validation-for="LastName"></span><br />

    Company: <input asp-for="CompanyName" />
    <span asp-validation-for="CompanyName"></span><br />

    Email: <input asp-for="EmailId" />
    <span asp-validation-for="EmailId"></span><br />

    Mobile: <input asp-for="MobileNo" />
    <span asp-validation-for="MobileNo"></span><br />

    Designation: <input asp-for="Designation" />
    <span asp-validation-for="Designation"></span><br />

    <button type="submit">Save</button>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
