@model List<Course>

    <table class="table">
        <tr>
            <th>Course Id</th>
            <th>Course Name</th>
            <th>Students</th>
        </tr>

    @foreach(var item in Model)
    {
        <tr>
            <td>@item.CourseId</td>
            <td>@item.CourseName</td>
            <td>
                <ul>
                    @foreach(var stud in item.Students)
                    {
                        <li>@stud.StudentName</li>
                    }
                </ul>
            </td>
        </tr>
    }
</table>
