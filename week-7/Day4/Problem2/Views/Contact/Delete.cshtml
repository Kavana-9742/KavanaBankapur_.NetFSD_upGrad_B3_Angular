@model Contact_Management.Models.ContactInfo

@{
    ViewData["Title"] = "Delete Contact";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <div class="card border-danger">
                <div class="card-header bg-danger text-white">
                    <h4><i class="bi bi-exclamation-triangle"></i> Delete Contact</h4>
                </div>
                <div class="card-body">
                    <div class="alert alert-warning">
                        <strong>Warning!</strong> Are you sure you want to delete this contact?
                    </div>

                    <dl class="row">
                        <dt class="col-sm-4">Full Name:</dt>
                        <dd class="col-sm-8">@Model.FirstName @Model.LastName</dd>

                        <dt class="col-sm-4">Email:</dt>
                        <dd class="col-sm-8">@Model.EmailId</dd>

                        <dt class="col-sm-4">Mobile:</dt>
                        <dd class="col-sm-8">@Model.MobileNo</dd>

                        <dt class="col-sm-4">Designation:</dt>
                        <dd class="col-sm-8">@Model.Designation</dd>

                        <dt class="col-sm-4">Company:</dt>
                        <dd class="col-sm-8">@Model.Company.CompanyName</dd>

                        <dt class="col-sm-4">Department:</dt>
                        <dd class="col-sm-8">@Model.Department.DepartmentName</dd>
                    </dl>

                    <form asp-action="DeleteConfirmed" asp-route-id="@Model.ContactId" method="post">
                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <button type="submit" class="btn btn-danger">
                                <i class="bi bi-trash"></i> Yes, Delete
                            </button>
                            <a asp-action="Index" class="btn btn-secondary">
                                <i class="bi bi-x-circle"></i> No, Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
