@model Contact_Management.Models.ContactInfo

@{
    ViewData["Title"] = "Contact Details";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h4><i class="bi bi-person-badge"></i> Contact Details</h4>
                </div>
                <div class="card-body">
                    <dl class="row">
                        <dt class="col-sm-4">Full Name:</dt>
                        <dd class="col-sm-8">@Model.FirstName @Model.LastName</dd>

                        <dt class="col-sm-4">Email:</dt>
                        <dd class="col-sm-8">
                            <a href="mailto:@Model.EmailId">@Model.EmailId</a>
                        </dd>

                        <dt class="col-sm-4">Mobile:</dt>
                        <dd class="col-sm-8">
                            <a href="tel:@Model.MobileNo">@Model.MobileNo</a>
                        </dd>

                        <dt class="col-sm-4">Designation:</dt>
                        <dd class="col-sm-8">@Model.Designation</dd>

                        <dt class="col-sm-4">Company:</dt>
                        <dd class="col-sm-8">
                            <span class="badge bg-info">@Model.Company.CompanyName</span>
                        </dd>

                        <dt class="col-sm-4">Department:</dt>
                        <dd class="col-sm-8">
                            <span class="badge bg-secondary">@Model.Department.DepartmentName</span>
                        </dd>
                    </dl>
                </div>
                <div class="card-footer">
                    <a asp-action="Edit" asp-route-id="@Model.ContactId" class="btn btn-warning">
                        <i class="bi bi-pencil"></i> Edit
                    </a>
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="bi bi-arrow-left"></i> Back to List
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>