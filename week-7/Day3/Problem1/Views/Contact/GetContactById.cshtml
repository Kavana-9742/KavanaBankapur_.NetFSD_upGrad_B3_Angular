@{
}

@model WebApplication6.Models.ContactInfo

<h2 style="color:purple;">Contact Details</h2>

@if (Model != null)
{
    <p><b>Contact Id:</b> @Model.ContactId</p>
    <p><b>First Name:</b> @Model.FirstName</p>
    <p><b>Last Name:</b> @Model.LastName</p>
    <p><b>Company Name:</b> @Model.CompanyName</p>
    <p><b>Email Id:</b> @Model.EmailId</p>
    <p><b>Mobile No:</b> @Model.MobileNo</p>
    <p><b>Designation:</b> @Model.Designation</p>
}
else
{
    <p style="color:red;">Contact not found</p>
}

<br />
<a asp-controller="Contact" asp-action="ShowContacts">Back to List</a>
