@model Movie_Catalog.Models.Movie

<h2>Add Movie</h2>

<form asp-action="Create" method="post">
    Title: <input asp-for="Title" /><br /><br/>
    Genre: <input asp-for="Genre" /><br /><br/>
    Release Date: <input asp-for="ReleaseDate" /><br /><br/>
    Price: <input asp-for="Price" /><br /><br/>
    Rating: <input asp-for="Rating" /><br /><br/>

    <input type="submit" value="Save" />
</form>