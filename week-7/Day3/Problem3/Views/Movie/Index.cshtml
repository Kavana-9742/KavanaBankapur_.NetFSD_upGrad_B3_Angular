@{
}

@model List<Movie_Catalog.Models.Movie>

<h2>Movie List</h2>

<a asp-action="Create">Add New Movie</a>

<table border="1" cellpadding="10" cellspacing="0" class="table">
    <tr>
        <th>Title</th>
        <th>Genre</th>
        <th>Price</th>
        <th>Actions</th>
    </tr>

    @foreach (var m in Model)
    {
        <tr>
            <td>@m.Title</td>
            <td>@m.Genre</td>
            <td>@m.Price</td>
            <td>
                <a asp-action="Edit" asp-route-id="@m.Id">Edit</a> |
                <a asp-action="Delete" asp-route-id="@m.Id">Delete</a> |
                <a asp-action="Details" asp-route-id="@m.Id">Details</a>
            </td>
        </tr>
    }
</table>